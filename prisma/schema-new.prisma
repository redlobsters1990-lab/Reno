generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== ENUMS ==========
enum ProjectStatus {
  active
  archived
}

enum FileType {
  floor_plan
  quote
  inspiration
  other
}

enum MemoryStatus {
  active
  resolved
  dismissed
}

enum ChatRole {
  user
  assistant
  system
}

enum QuoteStatus {
  draft
  parsed
  reviewed
}

enum EstimateConfidence {
  low
  medium
  high
}

enum ConversationStatus {
  active
  archived
  completed
}

enum JobStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum JobType {
  cost_estimation
  quote_analysis
  memory_processing
  file_processing
  chat_generation
}

enum ActivityType {
  login
  logout
  project_create
  project_update
  project_delete
  chat_message
  file_upload
  cost_estimate
  quote_upload
  job_started
  job_completed
  job_failed
  settings_update
}

enum CostEventType {
  chat_message
  cost_estimation
  quote_analysis
  file_processing
  memory_processing
}

// ========== MODELS ==========

model User {
  id            String                 @id @default(cuid())
  name          String?
  email         String                 @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          String                 @default("user")
  status        String                 @default("active")
  lastActiveAt  DateTime?              @updatedAt
  deletedAt     DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  
  // Relations
  accounts              Account[]
  sessions              Session[]
  projects              Project[]
  conversations         Conversation[]
  chatMessages          ChatMessage[]
  longTermMemories      UserLongTermMemory[]
  projectMemories       ProjectShortTermMemory[]
  projectSessions       ProjectSession[]
  uploadedFiles         UploadedFile[]
  costEstimates         CostEstimate[]
  contractorQuotes      ContractorQuote[]
  quoteLineItems        QuoteLineItem[]
  jobs                  Job[]
  activities            UserActivity[]
  costEvents            CostEvent[]

  @@index([email])
  @@index([status, createdAt])
  @@index([lastActiveAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
  @@index([expires])
}

model Project {
  id              String                   @id @default(cuid())
  userId          String
  title           String
  propertyType    String
  roomCount       Int?
  budget          Float?
  stylePreference String?
  notes           String?                  @db.Text
  status          ProjectStatus            @default(active)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  
  // Relations
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations      Conversation[]
  projectMemories    ProjectShortTermMemory[]
  projectSessions    ProjectSession[]
  uploadedFiles      UploadedFile[]
  costEstimates      CostEstimate[]
  contractorQuotes   ContractorQuote[]
  chatMessages       ChatMessage[]

  @@index([userId, createdAt])
  @@index([status, updatedAt])
}

model Conversation {
  id          String              @id @default(cuid())
  userId      String
  projectId   String?
  title       String?
  status      ConversationStatus  @default(active)
  metadata    String?             @db.Text
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  
  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]
  jobs        Job[]

  @@index([userId, createdAt])
  @@index([projectId, status])
  @@index([status, updatedAt])
}

model ChatMessage {
  id             String      @id @default(cuid())
  userId         String
  conversationId String
  projectId      String?
  role           ChatRole
  content        String      @db.Text
  metadata       String?     @db.Text
  createdAt      DateTime    @default(now())
  
  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@index([projectId, createdAt])
}

model UserLongTermMemory {
  id          String   @id @default(cuid())
  userId      String
  memoryKey   String
  memoryValue String   @db.Text
  confidence  Float    @default(0.7)
  source      String
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, memoryKey])
  @@index([userId, updatedAt])
}

model ProjectShortTermMemory {
  id         String       @id @default(cuid())
  userId     String
  projectId  String
  memoryType String
  note       String       @db.Text
  status     MemoryStatus @default(active)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status, createdAt])
  @@index([userId, projectId])
}

model ProjectSession {
  id                 String   @id @default(cuid())
  userId             String
  projectId          String
  openclawSessionKey String   @unique
  lastActiveAt       DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId, lastActiveAt])
  @@index([userId, lastActiveAt])
}

model UploadedFile {
  id           String   @id @default(cuid())
  userId       String
  projectId    String
  fileType     FileType
  filePath     String
  originalName String
  mimeType     String
  sizeBytes    Int?
  createdAt    DateTime @default(now())
  
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([projectId, fileType, createdAt])
}

model CostEstimate {
  id              String              @id @default(cuid())
  userId          String
  projectId       String
  leanMin         Float
  leanMax         Float
  realisticMin    Float
  realisticMax    Float
  stretchMin      Float
  stretchMax      Float
  confidence      EstimateConfidence
  assumptions     String              @db.Text
  costDrivers     String              @db.Text
  estimatorInputs String              @db.Text
  createdAt       DateTime            @default(now())
  
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
}

model ContractorQuote {
  id               String          @id @default(cuid())
  userId           String
  projectId        String
  contractorName   String
  totalAmount      Float?
  currency         String          @default("SGD")
  status           QuoteStatus     @default(draft)
  notes            String?         @db.Text
  parsingSummary   String?         @db.Text
  warnings         String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineItems  QuoteLineItem[]

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
}

model QuoteLineItem {
  id          String           @id @default(cuid())
  userId      String
  quoteId     String
  description String
  quantity    Float?
  unit        String?
  unitPrice   Float?
  totalPrice  Float?
  category    String?
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())
  
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote ContractorQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([quoteId, category])
}

model Job {
  id            String   @id @default(cuid())
  userId        String
  conversationId String?
  projectId     String?
  jobType       JobType
  status        JobStatus
  input         String?  @db.Text
  output        String?  @db.Text
  error         String?  @db.Text
  metadata      String?  @db.Text
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([jobType, status, startedAt])
  @@index([conversationId, createdAt])
  @@index([projectId, createdAt])
}

model UserActivity {
  id          String        @id @default(cuid())
  userId      String
  activityType ActivityType
  entityType  String?       // e.g., "Project", "ChatMessage", "File"
  entityId    String?       // ID of the affected entity
  description String        @db.Text
  metadata    String?       @db.Text
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime      @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([activityType, createdAt])
  @@index([entityType, entityId])
}

model CostEvent {
  id          String        @id @default(cuid())
  userId      String
  projectId   String?
  conversationId String?
  jobId       String?
  eventType   CostEventType
  units       Float         // e.g., message count, processing seconds
  cost        Float?        // monetary cost if applicable
  currency    String        @default("USD")
  metadata    String?     @db.Text
  createdAt   DateTime    @default(now())
  
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  job          Job?         @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([projectId, createdAt])
}