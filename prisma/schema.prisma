generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  active
  archived
}

enum FileType {
  floor_plan
  quote
  inspiration
  other
}

enum MemoryStatus {
  active
  resolved
  dismissed
}

enum ChatRole {
  user
  assistant
  system
}

enum QuoteStatus {
  draft
  parsed
  reviewed
}

enum EstimateConfidence {
  low
  medium
  high
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String                 @unique
  emailVerified         DateTime?
  passwordHash          String?
  image                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  accounts              Account[]
  sessions              Session[]
  projects              Project[]
  longTermMemories      UserLongTermMemory[]
  projectMemories       ProjectShortTermMemory[]
  projectSessions       ProjectSession[]
  chatMessages          ChatMessage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id                    String                   @id @default(cuid())
  userId                String
  title                 String
  propertyType          String
  roomCount             Int?
  budget                Float?
  stylePreference       String?
  notes                 String?                  @db.Text
  status                ProjectStatus            @default(active)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectMemories       ProjectShortTermMemory[]
  projectSessions       ProjectSession[]
  uploadedFiles         UploadedFile[]
  estimates             CostEstimate[]
  contractorQuotes      ContractorQuote[]
  chatMessages          ChatMessage[]

  @@index([userId, createdAt])
}

model UserLongTermMemory {
  id          String   @id @default(cuid())
  userId      String
  memoryKey   String
  memoryValue String   @db.Text
  confidence  Float    @default(0.7)
  source      String
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, memoryKey])
  @@index([userId, updatedAt])
}

model ProjectShortTermMemory {
  id         String       @id @default(cuid())
  userId     String
  projectId  String
  memoryType String
  note       String       @db.Text
  status     MemoryStatus @default(active)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status, createdAt])
  @@index([userId, projectId])
}

model ProjectSession {
  id                 String   @id @default(cuid())
  userId             String
  projectId          String
  openclawSessionKey String   @unique
  lastActiveAt       DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId, lastActiveAt])
}

model UploadedFile {
  id           String   @id @default(cuid())
  projectId    String
  fileType     FileType
  filePath     String
  originalName String
  mimeType     String
  sizeBytes    Int?
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, fileType, createdAt])
}

model CostEstimate {
  id              String              @id @default(cuid())
  projectId       String
  leanMin         Float
  leanMax         Float
  realisticMin    Float
  realisticMax    Float
  stretchMin      Float
  stretchMax      Float
  confidence      EstimateConfidence
  assumptions     String              @db.Text
  costDrivers     String              @db.Text
  estimatorInputs String              @db.Text
  createdAt       DateTime            @default(now())
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model ContractorQuote {
  id               String          @id @default(cuid())
  projectId        String
  contractorName   String
  totalAmount      Float?
  currency         String          @default("SGD")
  status           QuoteStatus     @default(draft)
  notes            String?         @db.Text
  parsingSummary   String?         @db.Text
  warnings         String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lineItems        QuoteLineItem[]

  @@index([projectId, createdAt])
}

model QuoteLineItem {
  id          String           @id @default(cuid())
  quoteId     String
  description String
  quantity    Float?
  unit        String?
  unitPrice   Float?
  totalPrice  Float?
  category    String?
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())
  quote       ContractorQuote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, category])
}

model ChatMessage {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  role        ChatRole
  content     String   @db.Text
  createdAt   DateTime @default(now())
  metadata    String?  @db.Text
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}
