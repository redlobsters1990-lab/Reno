generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String                   @id @default(cuid())
  name             String?
  email            String                   @unique
  emailVerified    DateTime?
  passwordHash     String?
  image            String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  role             String?                  @default("user")
  status           String?                  @default("active")
  lastActiveAt     DateTime?                @updatedAt @db.Timestamp(6)
  deletedAt        DateTime?                @db.Timestamp(6)
  accounts         Account[]
  chatMessages     ChatMessage[]
  contractorQuotes ContractorQuote[]
  conversations    Conversation[]
  costEstimates    CostEstimate[]
  costEvents       CostEvent[]
  jobs             Job[]
  projects         Project[]
  projectSessions  ProjectSession[]
  projectMemories  ProjectShortTermMemory[]
  quoteLineItems   QuoteLineItem[]
  sessions         Session[]
  uploadedFiles    UploadedFile[]
  activities       UserActivity[]
  longTermMemories UserLongTermMemory[]

  @@index([email])
  @@index([status, createdAt])
  @@index([lastActiveAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
  @@unique([identifier, token])
}

model Project {
  id               String                   @id @default(cuid())
  userId           String
  title            String
  propertyType     String
  roomCount        Int?
  budget           Float?
  stylePreference  String?
  notes            String?
  status           ProjectStatus            @default(active)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  deletedAt        DateTime?                @db.Timestamp(6)
  chatMessages     ChatMessage[]
  contractorQuotes ContractorQuote[]
  conversations    Conversation[]
  costEstimates    CostEstimate[]
  costEvents       CostEvent[]
  jobs             Job[]
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectSessions  ProjectSession[]
  projectMemories  ProjectShortTermMemory[]
  uploadedFiles    UploadedFile[]
  quotes           Quote[]

  @@index([userId, createdAt])
}

model Conversation {
  id         String              @id @default(cuid())
  userId     String
  projectId  String?
  title      String?
  status     ConversationStatus? @default(active)
  metadata   String?
  createdAt  DateTime            @default(now()) @db.Timestamp(6)
  updatedAt  DateTime            @default(now()) @updatedAt @db.Timestamp(6)
  messages   ChatMessage[]
  project    Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  costEvents CostEvent[]
  jobs       Job[]

  @@index([userId, createdAt])
  @@index([projectId, status])
  @@index([status, updatedAt])
}

model ChatMessage {
  id             String       @id @default(cuid())
  userId         String
  projectId      String?
  role           ChatRole
  content        String
  createdAt      DateTime     @default(now())
  metadata       String?
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([projectId, createdAt])
  @@index([userId])
}

model UserLongTermMemory {
  id          String   @id @default(cuid())
  userId      String
  memoryKey   String
  memoryValue String
  confidence  Float    @default(0.7)
  source      String
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, memoryKey])
  @@index([userId, updatedAt])
}

model ProjectShortTermMemory {
  id         String       @id @default(cuid())
  userId     String
  projectId  String
  memoryType String
  note       String
  status     MemoryStatus @default(active)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, status, createdAt])
  @@index([userId, projectId])
}

model ProjectSession {
  id                 String   @id @default(cuid())
  userId             String
  projectId          String
  openclawSessionKey String   @unique
  lastActiveAt       DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId, lastActiveAt])
}

model UploadedFile {
  id           String   @id @default(cuid())
  projectId    String
  fileType     FileType
  filePath     String
  originalName String
  mimeType     String
  sizeBytes    Int?
  createdAt    DateTime @default(now())
  userId       String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([projectId, fileType, createdAt])
  @@index([userId])
}

model CostEstimate {
  id              String             @id @default(cuid())
  projectId       String
  leanMin         Float
  leanMax         Float
  realisticMin    Float
  realisticMax    Float
  stretchMin      Float
  stretchMax      Float
  confidence      EstimateConfidence
  assumptions     String
  costDrivers     String
  estimatorInputs String
  createdAt       DateTime           @default(now())
  userId          String
  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([projectId, createdAt])
  @@index([userId])
}

model ContractorQuote {
  id             String          @id @default(cuid())
  projectId      String
  contractorName String
  totalAmount    Float?
  currency       String          @default("SGD")
  status         QuoteStatus     @default(draft)
  notes          String?
  parsingSummary String?
  warnings       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  userId         String
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  lineItems      QuoteLineItem[]

  @@index([projectId, createdAt])
  @@index([userId])
}

model QuoteLineItem {
  id          String          @id @default(cuid())
  quoteId     String
  description String
  quantity    Float?
  unit        String?
  unitPrice   Float?
  totalPrice  Float?
  category    String?
  notes       String?
  createdAt   DateTime        @default(now())
  userId      String
  quote       ContractorQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([quoteId, category])
  @@index([userId])
}

model Job {
  id             String        @id @default(cuid())
  userId         String
  conversationId String?
  projectId      String?
  jobType        JobType
  status         JobStatus?    @default(pending)
  input          String?
  output         String?
  error          String?
  metadata       String?
  startedAt      DateTime      @default(now()) @db.Timestamp(6)
  completedAt    DateTime?     @db.Timestamp(6)
  createdAt      DateTime      @default(now()) @db.Timestamp(6)
  updatedAt      DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  costEvents     CostEvent[]
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, status, createdAt])
  @@index([jobType, status, startedAt])
  @@index([conversationId, createdAt])
  @@index([projectId, createdAt])
}

model UserActivity {
  id           String       @id @default(cuid())
  userId       String
  activityType ActivityType
  entityType   String?
  entityId     String?
  description  String
  metadata     String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime     @default(now()) @db.Timestamp(6)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt])
  @@index([activityType, createdAt])
  @@index([entityType, entityId])
}

model CostEvent {
  id             String        @id @default(cuid())
  userId         String
  projectId      String?
  conversationId String?
  jobId          String?
  eventType      CostEventType
  units          Float
  cost           Float?
  currency       String?       @default("USD")
  metadata       String?
  createdAt      DateTime      @default(now()) @db.Timestamp(6)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  job            Job?          @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([projectId, createdAt])
  @@index([conversationId])
  @@index([jobId])
}

enum ProjectStatus {
  active
  archived
}

enum FileType {
  floor_plan
  quote
  inspiration
  other
}

enum MemoryStatus {
  active
  resolved
  dismissed
}

enum ChatRole {
  user
  assistant
  system
}

enum QuoteStatus {
  draft
  parsed
  reviewed
}

enum EstimateConfidence {
  low
  medium
  high
}

enum ConversationStatus {
  active
  archived
  completed
}

enum JobStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum JobType {
  cost_estimation
  quote_analysis
  memory_processing
  file_processing
  chat_generation
}

enum ActivityType {
  login
  logout
  project_create
  project_update
  project_delete
  chat_message
  file_upload
  cost_estimate
  quote_upload
  job_started
  job_completed
  job_failed
  settings_update
}

enum CostEventType {
  chat_message
  cost_estimation
  quote_analysis
  file_processing
  memory_processing
}

// Model for uploaded contractor quotes with AI analysis
model Quote {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractorName String
  companyName    String?
  amount         Float
  fileUrl        String
  fileName       String
  fileType       String
  status         String   @default("pending") // pending, analyzing, analyzed, error
  analysis       String?  @db.Text // JSON string of AI analysis
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
}
